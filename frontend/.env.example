# Example Environment Configuration for Frontend
# Copy this file to .env and configure your values

# Email Domain Restriction Configuration
# ===========================================
# 
# Configure which email domains are allowed to log in.
# 
# Format:
#   - Single domain: VITE_ALLOWED_EMAIL_DOMAINS=nriit.edu.in
#   - Multiple domains (comma-separated): VITE_ALLOWED_EMAIL_DOMAINS=nriit.edu.in,amman.ac.in
#   - Allow all emails: VITE_ALLOWED_EMAIL_DOMAINS= (leave empty or comment out)
# 
# Examples:
# VITE_ALLOWED_EMAIL_DOMAINS=nriit.edu.in
# VITE_ALLOWED_EMAIL_DOMAINS=nriit.edu.in,amman.ac.in,college.edu
#
# Default: Allow all emails (leave empty)
VITE_ALLOWED_EMAIL_DOMAINS=

# Backend API URL
# ===========================================
# For localhost development (default) - leave empty or use:
# VITE_API_URL=http://localhost:3000
#
# For production or Cloudflare tunnel:
# VITE_API_URL=https://your-backend-url.com
VITE_API_URL=
